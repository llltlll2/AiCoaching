[Unit]
Description=gunicorn daemon for AI Coaching Platform
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/var/www/aicoaching/backend
ExecStart=/var/www/aicoaching/venv/bin/gunicorn \
          --access-logfile - \
          --workers 3 \
          --bind unix:/var/www/aicoaching/aicoaching.sock \
          config.wsgi:application

[Install]
WantedBy=multi-user.target
